pipeline {
    agent any

    environment {
        IMAGE_NAME = "nginx:latest"
        IMAGE_TAG  = "${BUILD_NUMBER}"
        GIT_REPO   = "https://github.com/suneeta989/Jenkins_Pipeline.git"
        GIT_BRANCH = "main"
    }

    stages {

        stage('Checkout Manifest Repository') {
            steps {
                git branch: "${main}",
                    url: "${GIT_REPO}"
            }
        }

        stage('Update Deployment Manifest') {
            steps {
                sh """
                sed -i 's|image: .*|image: ${IMAGE_NAME}:${IMAGE_TAG}|g' deployment.yml
                cat deployment.yml
                """
            }
        }

        stage('Commit Changes') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'github-creds',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )
                ]) {
                    sh """
                    git config user.email "suneeta.dharwadkar11@gmail.com"
                    git config user.name "suneeta989"

                    git add deployment.yml
                    git commit -m "Update image to ${IMAGE_TAG}" || true

                    git remote set-url origin https://${GIT_USER}:${GIT_TOKEN}@github.com/suneeta989/Jenkins_Pipeline.git
                    git push origin ${GIT_BRANCH}
                    """
                }
            }
        }
    }
}
